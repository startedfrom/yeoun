APP_ENV=development

# apps/api
API_PORT=4000
API_HOST=0.0.0.0
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gamdojang
# 쉼표로 여러 출처. 웹·앱에서 쓰는 출처를 모두 넣을 것.
# Vercel 프론트(예: https://yeoun-admin.vercel.app/splash는 코드에서 *.vercel.app 을 허용하지만,
# 그 외 커스텀 도메인은 여기에 추가해야 한다.
CORS_ORIGIN=http://localhost:8081,http://localhost:5173,http://127.0.0.1:5173

# apps/mobile
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_SCHEME=gamdojang
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# ---- Render (API Web Service) ----
# 원본은 render.yaml + scripts/render-api-{build,start}.sh 입니다.
# 대시보드에 Build/Start 를 따로 넣었다가 이어 붙이면 `buildpnpm` 처럼 되어 API 빌드가 스킵될 수 있으니,
# 비워 두고 Blueprint 만 쓰는 것을 권장합니다.

# ---- Vercel (Expo 웹) ----
# 빌드 시점에 들어가므로 값 바꾼 뒤 Redeploy 할 것. 로컬 주소 금지.
# EXPO_PUBLIC_API_BASE_URL=https://당신의-API-호스트/api/v1
