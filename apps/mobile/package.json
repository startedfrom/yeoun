{
  "name": "@gamdojang/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start --clear",
    "start": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start",
    "start:clear": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo start --clear",
    "ios": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo run:ios",
    "android": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo run:android",
    "lint": "eslint app src app.config.ts --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo export --platform ios --platform android --output-dir dist",
    "build:web": "EXPO_NO_METRO_WORKSPACE_ROOT=1 expo export --platform web --output-dir dist"
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.9",
    "@gamdojang/domain": "workspace:*",
    "@gamdojang/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.99.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "expo": "^55.0.15",
    "expo-constants": "^55.0.14",
    "expo-device": "^55.0.15",
    "expo-font": "^55.0.6",
    "expo-haptics": "^55.0.14",
    "expo-image-picker": "^55.0.18",
    "expo-notifications": "^55.0.19",
    "expo-router": "^55.0.12",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "^55.0.18",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.72.1",
    "react-native": "^0.83.4",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.23.0",
    "react-native-web": "^0.21.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
